{
  "name": "xenia-home-card",
  "version": "0.2.0-beta.0",
  "description": "Home Assistant Lovelace card for visualizing espresso shots from the Xenia espresso machine",
  "main": "dist/xenia-home-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit -p tsconfig.test.json",
    "analyze:lit": "lit-analyzer \"src/**/*.ts\" --globalTags ha-card,ha-icon,ha-icon-button,ha-form,ha-formfield,ha-textfield,ha-selector",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Knoedelauflauf/xenia-home-card.git"
  },
  "bugs": {
    "url": "https://github.com/Knoedelauflauf/xenia-home-card/issues"
  },
  "homepage": "https://github.com/Knoedelauflauf/xenia-home-card#readme",
  "keywords": [
    "home-assistant",
    "lovelace",
    "espresso",
    "xenia",
    "hacs"
  ],
  "author": "Knoedelauflauf",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@open-wc/testing-helpers": "^3.0.1",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-lit": "2.3.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-wc": "3.1.0",
    "globals": "17.6.0",
    "happy-dom": "^20.9.0",
    "lit": "^3.3.3",
    "lit-analyzer": "2.0.3",
    "prettier": "3.8.3",
    "rollup": "^4.24.0",
    "ts-lit-plugin": "2.0.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
